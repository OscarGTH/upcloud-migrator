#!/usr/bin/env sh
# Validates that the commit message follows Conventional Commits.
# https://www.conventionalcommits.org/

MSG=$(cat "$1")

# Allow merge commits and revert commits through unchanged
case "$MSG" in
  Merge\ *|Revert\ *) exit 0 ;;
esac

PATTERN='^(feat|fix|docs|style|refactor|perf|test|chore|ci|build|revert)(\([^)]+\))?!?:\ .+'

if ! echo "$MSG" | grep -qE "$PATTERN"; then
  echo ""
  echo "  ✗ Commit message does not follow Conventional Commits format."
  echo ""
  echo "  Expected:  <type>(<scope>): <description>"
  echo "  Examples:  feat: add Azure provider"
  echo "             fix(network): resolve firewall merge bug"
  echo "             feat!: redesign provider API"
  echo ""
  echo "  Valid types: feat fix docs style refactor perf test chore ci build revert"
  echo ""
  exit 1
fi
